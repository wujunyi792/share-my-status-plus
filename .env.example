# Share My Status - Docker Environment Configuration

# =============================================================================
# 应用配置 (Go程序使用)
# =============================================================================
APP_NAME=share-my-status
APP_VERSION=1.0.0
APP_ENV=production
HTTP_PORT=8080
DEBUG=false
DEFAULT_TZ=Asia/Shanghai
REDIRECT_DEFAULT_TARGET=http://localhost:3000/{SharingKey}

# =============================================================================
# 数据库配置 (Go程序使用)
# =============================================================================
DB_DSN=share_user:share_password@tcp(mysql:3306)/share_my_status?charset=utf8mb4&parseTime=True&loc=Local
DB_MAX_IDLE_CONNS=10
DB_MAX_OPEN_CONNS=100
DB_CONN_MAX_LIFETIME=3600

# =============================================================================
# Redis配置 (Go程序使用)
# =============================================================================
REDIS_URL=redis://redis:6379/0
REDIS_PASSWORD=
REDIS_DB=0

# =============================================================================
# 飞书配置 (Go程序使用)
# =============================================================================
FEISHU_APP_ID=your_feishu_app_id
FEISHU_APP_SECRET=your_feishu_app_secret

# =============================================================================
# 日志配置 (Go程序使用)
# =============================================================================
LOG_LEVEL=info
LOG_FORMAT=json

# =============================================================================
# 定时任务配置 (Go程序使用)
# =============================================================================
SCHEDULER_ENABLED=true
SCHEDULER_CLEANUP_CRON=0 * * * *
SCHEDULER_SNAPSHOT_RETENTION_HOURS=24

# =============================================================================
# Docker Compose 服务配置 (仅用于容器配置，不被Go程序使用)
# =============================================================================
# MySQL 容器配置
MYSQL_ROOT_PASSWORD=root_password_change_me
MYSQL_DATABASE=share_my_status
MYSQL_USER=share_user
MYSQL_PASSWORD=share_password

# Grafana 配置
GRAFANA_ADMIN_USER=admin
GRAFANA_ADMIN_PASSWORD=admin_password_change_me

# Prometheus 配置
PROMETHEUS_RETENTION_TIME=15d

# 数据卷配置
MYSQL_DATA_PATH=./data/mysql
REDIS_DATA_PATH=./data/redis
PROMETHEUS_DATA_PATH=./data/prometheus
GRAFANA_DATA_PATH=./data/grafana