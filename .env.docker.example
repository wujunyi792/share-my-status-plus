# Share My Status Plus - Docker Environment Configuration
# 复制此文件为 .env.docker 并根据实际情况修改配置

# =============================================================================
# 应用配置
# =============================================================================
APP_NAME=share-my-status
APP_ENV=production
APP_DEBUG=false
APP_PORT=8080
APP_HOST=0.0.0.0

# =============================================================================
# 数据库配置 (MySQL)
# =============================================================================
# 重要：生产环境必须修改默认密码！
MYSQL_ROOT_PASSWORD=change_this_root_password_in_production
MYSQL_DATABASE=share_my_status
MYSQL_USER=share_user
MYSQL_PASSWORD=change_this_password_in_production
MYSQL_HOST=mysql
MYSQL_PORT=3306

# 数据库连接池配置
DB_MAX_OPEN_CONNS=100
DB_MAX_IDLE_CONNS=10
DB_CONN_MAX_LIFETIME=3600

# =============================================================================
# Redis 配置
# =============================================================================
REDIS_HOST=redis
REDIS_PORT=6379
REDIS_PASSWORD=
REDIS_DB=0
REDIS_MAX_RETRIES=3
REDIS_POOL_SIZE=10

# =============================================================================
# 飞书配置
# =============================================================================
# 请在飞书开放平台获取应用凭证
FEISHU_APP_ID=your_feishu_app_id_here
FEISHU_APP_SECRET=your_feishu_app_secret_here
FEISHU_ENCRYPT_KEY=your_feishu_encrypt_key_here
FEISHU_VERIFICATION_TOKEN=your_feishu_verification_token_here

# =============================================================================
# 日志配置
# =============================================================================
LOG_LEVEL=info
LOG_FORMAT=json
LOG_OUTPUT=stdout
LOG_MAX_SIZE=100
LOG_MAX_BACKUPS=7
LOG_MAX_AGE=30

# =============================================================================
# 安全配置
# =============================================================================
# 重要：生产环境必须使用强密钥！
JWT_SECRET=your_jwt_secret_key_here_make_it_long_and_random
JWT_EXPIRE_HOURS=24
ENCRYPTION_KEY=your_encryption_key_32_chars_long
CORS_ALLOWED_ORIGINS=http://localhost:3000,http://localhost:8080

# =============================================================================
# 限流配置
# =============================================================================
RATE_LIMIT_ENABLED=true
RATE_LIMIT_REQUESTS=100
RATE_LIMIT_WINDOW=60
RATE_LIMIT_BURST=10

# =============================================================================
# 可观测性配置
# =============================================================================
# 指标收集
METRICS_ENABLED=true
METRICS_PORT=9090
METRICS_PATH=/metrics

# 链路追踪
TRACING_ENABLED=true
JAEGER_ENDPOINT=http://jaeger:14268/api/traces
JAEGER_SERVICE_NAME=share-my-status-backend

# =============================================================================
# MySQL 配置
# =============================================================================
MYSQL_INNODB_BUFFER_POOL_SIZE=256M
MYSQL_MAX_CONNECTIONS=200
MYSQL_QUERY_CACHE_SIZE=64M

# =============================================================================
# Redis 配置
# =============================================================================
REDIS_MAXMEMORY=256mb
REDIS_MAXMEMORY_POLICY=allkeys-lru
REDIS_SAVE_ENABLED=true

# =============================================================================
# Grafana 配置
# =============================================================================
# 重要：生产环境必须修改默认密码！
GRAFANA_ADMIN_USER=admin
GRAFANA_ADMIN_PASSWORD=change_this_grafana_password_in_production
GRAFANA_ALLOW_SIGN_UP=false
GRAFANA_ANONYMOUS_ENABLED=false

# =============================================================================
# Prometheus 配置
# =============================================================================
PROMETHEUS_RETENTION_TIME=15d
PROMETHEUS_STORAGE_RETENTION_SIZE=10GB
PROMETHEUS_SCRAPE_INTERVAL=15s
PROMETHEUS_EVALUATION_INTERVAL=15s

# =============================================================================
# Loki 配置
# =============================================================================
LOKI_RETENTION_PERIOD=168h
LOKI_MAX_LOOK_BACK_PERIOD=0s

# =============================================================================
# Jaeger 配置
# =============================================================================
JAEGER_MEMORY_MAX_TRACES=50000
JAEGER_QUERY_BASE_PATH=/

# =============================================================================
# 网络配置
# =============================================================================
DOCKER_NETWORK_NAME=share-my-status-network
DOCKER_NETWORK_SUBNET=172.20.0.0/16

# =============================================================================
# 数据卷配置
# =============================================================================
MYSQL_DATA_PATH=./data/mysql
REDIS_DATA_PATH=./data/redis
GRAFANA_DATA_PATH=./data/grafana
PROMETHEUS_DATA_PATH=./data/prometheus
LOKI_DATA_PATH=./data/loki

# =============================================================================
# 健康检查配置
# =============================================================================
HEALTH_CHECK_INTERVAL=30s
HEALTH_CHECK_TIMEOUT=10s
HEALTH_CHECK_RETRIES=3
HEALTH_CHECK_START_PERIOD=60s

# =============================================================================
# 备份配置
# =============================================================================
BACKUP_RETENTION_DAYS=7
BACKUP_COMPRESSION=true
BACKUP_ENCRYPTION=false

# =============================================================================
# 开发配置（仅开发环境使用）
# =============================================================================
DEV_HOT_RELOAD=true
DEV_DEBUG_MODE=true
DEV_MOCK_FEISHU=false

# =============================================================================
# 性能调优
# =============================================================================
# Go 运行时配置
GOMAXPROCS=0
GOGC=100

# 服务器配置
SERVER_READ_TIMEOUT=30s
SERVER_WRITE_TIMEOUT=30s
SERVER_IDLE_TIMEOUT=120s
SERVER_MAX_HEADER_BYTES=1048576

# =============================================================================
# 监控告警配置
# =============================================================================
ALERT_WEBHOOK_URL=
ALERT_EMAIL_ENABLED=false
ALERT_EMAIL_SMTP_HOST=
ALERT_EMAIL_SMTP_PORT=587
ALERT_EMAIL_USERNAME=
ALERT_EMAIL_PASSWORD=
ALERT_EMAIL_FROM=
ALERT_EMAIL_TO=

# =============================================================================
# 扩展配置
# =============================================================================
# 文件上传
UPLOAD_MAX_SIZE=10MB
UPLOAD_ALLOWED_TYPES=image/jpeg,image/png,image/gif

# 缓存配置
CACHE_DEFAULT_TTL=3600
CACHE_MAX_ENTRIES=10000

# 会话配置
SESSION_TIMEOUT=86400
SESSION_CLEANUP_INTERVAL=3600

# =============================================================================
# 注意事项
# =============================================================================
# 1. 生产环境部署前，请务必修改所有包含 "change_this" 的配置项
# 2. 密码和密钥应使用强随机字符串
# 3. 根据实际资源情况调整内存和连接数配置
# 4. 定期轮换密钥和密码
# 5. 备份此配置文件到安全位置