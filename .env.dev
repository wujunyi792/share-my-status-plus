# Share My Status Plus - 本地开发环境配置
# 此文件用于后端本地开发，配合 docker-compose.dev.yml 使用

# =============================================================================
# 应用配置
# =============================================================================
APP_NAME=share-my-status-dev
APP_VERSION=1.0.0
APP_ENV=development
HTTP_PORT=8080
DEBUG=true
DEFAULT_TZ=Asia/Shanghai
REDIRECT_DEFAULT_TARGET=http://localhost:3000/s/{SharingKey}

# =============================================================================
# 数据库配置 (MySQL) - 开发环境
# =============================================================================
# 数据库连接字符串 - 根据docker-compose.dev.yml中的配置
DB_DSN=dev_user:dev123@tcp(localhost:3307)/share_my_status_dev?charset=utf8mb4&parseTime=True&loc=Local

# 数据库连接池配置
DB_MAX_OPEN_CONNS=20
DB_MAX_IDLE_CONNS=5
DB_CONN_MAX_LIFETIME=1800

# =============================================================================
# Redis 配置 - 开发环境
# =============================================================================
REDIS_URL=redis://localhost:6380
REDIS_PASSWORD=
REDIS_DB=0

# =============================================================================
# 飞书配置 - 开发环境
# =============================================================================
FEISHU_APP_ID=your_dev_feishu_app_id_here
FEISHU_APP_SECRET=your_dev_feishu_app_secret_here

# =============================================================================
# 日志配置 - 开发环境
# =============================================================================
LOG_LEVEL=debug
LOG_FORMAT=text

# =============================================================================
# 定时任务配置
# =============================================================================
SCHEDULER_ENABLED=true
SCHEDULER_CLEANUP_CRON=0 * * * *
SCHEDULER_SNAPSHOT_RETENTION_HOURS=24

# =============================================================================
# Docker Compose 服务配置 (仅用于容器配置，不被Go程序使用)
# =============================================================================
# MySQL 容器配置
MYSQL_ROOT_PASSWORD=root123
MYSQL_DATABASE=share_my_status_dev
MYSQL_USER=dev_user
MYSQL_PASSWORD=dev123

# 数据卷配置
MYSQL_DATA_PATH=./data/dev/mysql
REDIS_DATA_PATH=./data/dev/redis

# 网络配置
DOCKER_NETWORK_NAME=share-my-status-dev-network