<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE plist PUBLIC "-//Apple//DTD PLIST 1.0//EN" "http://www.apple.com/DTDs/PropertyList-1.0.dtd">
<plist version="1.0">
<dict>
	<!-- Sparkle auto-update configuration.
	     Standard CFBundle* keys are still injected by GENERATE_INFOPLIST_FILE=YES
	     and merged on top of this file at build time.
	     This file lives outside the synchronized source folder so it is never
	     treated as a bundle resource. -->

	<!-- Stable per-platform feed: a fixed rolling tag that always holds the newest macOS
	     appcast. Decoupled from the repo's single "Latest" release so Windows releases can't
	     break the macOS update feed (and vice versa). -->
	<key>SUFeedURL</key>
	<string>https://github.com/wujunyi792/share-my-status-plus/releases/download/desktop-macos-latest/appcast.xml</string>

	<!-- EdDSA public key. The matching private key signs each release's appcast in CI. -->
	<key>SUPublicEDKey</key>
	<string>jwvTxN7m454HZVnJmxB8+7EpzHt3yp85vZVc5UvGEaU=</string>

	<!-- Check for updates automatically in the background. -->
	<key>SUEnableAutomaticChecks</key>
	<true/>

	<!-- Check once per day (seconds). -->
	<key>SUScheduledCheckInterval</key>
	<integer>86400</integer>
</dict>
</plist>
