<Window x:Class="ShareMyStatusClient.Views.ProcessPickerWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="选择应用"
        Icon="pack://application:,,,/Resources/app.ico"
        Width="460" Height="580"
        MinWidth="380" MinHeight="420"
        WindowStartupLocation="CenterOwner"
        FontFamily="Segoe UI, Microsoft YaHei">
    <DockPanel Margin="12">
        <Border DockPanel.Dock="Bottom" Margin="0,10,0,0">
            <Grid>
                <Button x:Name="BtnRefresh" Content="刷新" Width="80" HorizontalAlignment="Left" Click="OnRefreshClick"/>
                <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
                    <Button Content="添加所选" Width="90" Margin="0,0,8,0" IsDefault="True" Click="OnOkClick"/>
                    <Button Content="取消" Width="80" IsCancel="True" Click="OnCancelClick"/>
                </StackPanel>
            </Grid>
        </Border>

        <TextBox x:Name="TxtSearch" DockPanel.Dock="Top" Margin="0,0,0,8"
                 TextChanged="OnSearchChanged"
                 ToolTip="搜索应用名或进程名"/>

        <TextBlock x:Name="LblStatus" DockPanel.Dock="Top" Margin="0,0,0,6"
                   Foreground="#777" Text="正在扫描运行中的应用…"/>

        <ListBox x:Name="List" ScrollViewer.HorizontalScrollBarVisibility="Disabled">
            <ListBox.ItemTemplate>
                <DataTemplate>
                    <CheckBox IsChecked="{Binding IsChecked, Mode=TwoWay}" Margin="2">
                        <StackPanel Margin="4,0,0,0">
                            <TextBlock Text="{Binding Display}" FontWeight="SemiBold" TextTrimming="CharacterEllipsis"/>
                            <TextBlock Text="{Binding Identifier}" Foreground="#888" FontSize="11" TextTrimming="CharacterEllipsis"/>
                        </StackPanel>
                    </CheckBox>
                </DataTemplate>
            </ListBox.ItemTemplate>
        </ListBox>
    </DockPanel>
</Window>
