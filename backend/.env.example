# =============================================================================
# 后端服务配置，复制为.env使用
# =============================================================================

# =============================================================================
# 应用配置
# =============================================================================
APP_NAME=share-my-status-dev
HTTP_PORT=8080
DEBUG=false
DEFAULT_TZ=Asia/Shanghai
REDIRECT_DEFAULT_TARGET=http://localhost:3000/ststus/{SharingKey}
ENDPOINT=http://localhost:8080

# =============================================================================
# 数据库配置 (PostgreSQL)
# =============================================================================
# 数据库连接字符串 - keyword/value 格式，与 Apple Finder 保持一致
DB_DSN=host=localhost user=status_sharing password=postgres_password_change_me dbname=status-sharing port=5432 sslmode=disable TimeZone=Asia/Shanghai
DB_MAX_OPEN_CONNS=20
DB_MAX_IDLE_CONNS=5
DB_CONN_MAX_LIFETIME=1800

# =============================================================================
# Redis 配置
# =============================================================================
REDIS_URL=redis://localhost:6379
REDIS_PASSWORD=redis_password_change_me
REDIS_DB=0

# =============================================================================
# 飞书配置
# =============================================================================
FEISHU_APP_ID=feishu_app_id_change_me
FEISHU_APP_SECRET=feishu_app_secret_change_me

# =============================================================================
# 日志配置
# LOG_LEVEL: panic, fatal, error, warn, info, debug, trace
# LOG_FORMAT: text, json
# =============================================================================
LOG_LEVEL=debug
LOG_FORMAT=json

# =============================================================================
# 旧版兼容性配置
# =============================================================================
LEGACY_CRYPTO_IV=''
LEGACY_CRYPTO_KEY=''
LEGACY_DEFAULT_JUMP_LINK=https://example.com
