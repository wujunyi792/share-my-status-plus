# Share My Status Backend Environment Configuration
# Application Configuration
APP_NAME=share-my-status
APP_VERSION=1.0.0
APP_ENV=development
HTTP_PORT=8080
DEBUG=true
DEFAULT_TZ=Asia/Shanghai

# Database Configuration
DB_DSN=root:password@tcp(127.0.0.1:3306)/share_my_status?charset=utf8mb4&parseTime=True&loc=Local
DB_MAX_IDLE_CONNS=10
DB_MAX_OPEN_CONNS=100
DB_CONN_MAX_LIFETIME=3600

# Redis Configuration
REDIS_URL=redis://localhost:6379
REDIS_PASSWORD=
REDIS_DB=0

# Feishu (Lark) Configuration
FEISHU_APP_ID=
FEISHU_APP_SECRET=

# Logging Configuration
LOG_LEVEL=info
LOG_FORMAT=json

curl -X POST http://localhost:8080/api/v1/state/report \
   -H "Content-Type: application/json" \
   -H "X-Secret-Key: 9215e5aa0298b9fdd6885c127716934dc24dc37bbba539df7a8f8d2783b4df0b" \
   -d '{
     "events": [
       {
         "version": "1",
         "ts": '1759768204000',
         "system": {
           "batteryPct": 0.75,
           "charging": true,
           "cpuPct": 0.45,
           "memoryPct": 0.70
         },
         "activity": {
           "label": "在开会"
         },
         "idempotencyKey": "test-batch-1-'1759768204000'"
       }
     ]
   }'