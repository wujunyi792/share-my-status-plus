# 用于后端本地开发的配置文件
# 注意：此配置文件仅用于本地开发，生产环境此配置文件不生效
# 使用：将此文件复制为.env至同目录下(backend/.env)，根据需要修改配置项

APP_NAME=share-my-status
APP_VERSION=1.0.0
APP_ENV=development
HTTP_PORT=8080
DEBUG=true
DEFAULT_TZ=Asia/Shanghai
REDIRECT_DEFAULT_TARGET=http://localhost:3000/s/{SharingKey}

# Database Configuration
DB_DSN=root:password@tcp(127.0.0.1:3306)/share_my_status?charset=utf8mb4&parseTime=True&loc=Local
DB_MAX_IDLE_CONNS=10
DB_MAX_OPEN_CONNS=100
DB_CONN_MAX_LIFETIME=3600

# Redis Configuration
REDIS_URL=redis://localhost:6379
REDIS_PASSWORD=
REDIS_DB=0

# Feishu (Lark) Configuration
FEISHU_APP_ID=
FEISHU_APP_SECRET=

# Logging Configuration
LOG_LEVEL=info
LOG_FORMAT=json